APP_ENV=production
PUBLIC_BASE_URL=https://api.example.com
STORE_BACKEND=postgres

DATABASE_URL=postgresql://dreamjourney:dreamjourney@postgres:5432/dreamjourney
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT_SECONDS=5
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
REDIS_URL=redis://redis:6379/0
BACKEND_API_TOKEN=

# Strong identity uses only keyed hashes at rest. Generate a dedicated random
# value of at least 32 bytes; never reuse a provider credential.
IDENTITY_BINDING_HMAC_KEY=
# Pin this version to the deployed HMAC key. Changing the key or version fails
# closed until an explicit identity rehash migration is performed.
IDENTITY_BINDING_HMAC_KEY_VERSION=v1
# disabled | synthetic | test. Synthetic/test are ignored in production.
IDENTITY_CHALLENGE_ADAPTER=disabled
# Development/test only. Never configure or deploy this value in production.
IDENTITY_CHALLENGE_SYNTHETIC_CODE=
IDENTITY_CHALLENGE_TTL_SECONDS=300
IDENTITY_CHALLENGE_MAX_ATTEMPTS=5
IDENTITY_CHALLENGE_RETRY_AFTER_SECONDS=30
# Development/test compatibility only; production always ignores this flag.
AUTH_LEGACY_PHONE_LOGIN_ENABLED=false

# Keep ownership in shadow until mismatch evidence has been reviewed.
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=2592000
# auto | shadow | enforce. auto resolves to enforce in production; invalid values stop startup.
AUTH_ROUTE_MODE=auto
AUTH_OWNERSHIP_MODE=shadow
# observe | enforce. Registry-classified USER mutations use RELEASE_POLICY_MIN_CLIENT_BUILD.
CLIENT_COMPATIBILITY_MODE=observe
# Global recovery traffic fence: normal | readOnly | signedOut | maintenance.
RECOVERY_ACCESS_MODE=normal
# Increment after a recovery cutover so clients invalidate stale authority state.
AUTHORITY_EPOCH=epoch-0
# Observe route/command policy mismatches before enabling server-side denial.
RELEASE_POLICY_COMMAND_MODE=observe
DELEGATED_ACCESS_CONTRACT_API_ENABLED=false
# Increment policy revision for every rollout, canary, restoration, or kill-switch change.
RELEASE_POLICY_REVISION=1
RELEASE_POLICY_MIN_CLIENT_BUILD=1
RELEASE_POLICY_TTL_SECONDS=300
# Comma-separated typed DJFeature names. Canary features enforce while global mode observes.
RELEASE_POLICY_ENFORCED_FEATURES=
# Kill switch always enforces; increment both revisions before changing this set.
RELEASE_POLICY_EMERGENCY_REVISION=0
RELEASE_POLICY_EMERGENCY_DISABLED_FEATURES=
# V4 async-effect kernel is schema-only until the worker readiness slice lands.
# Keep both disabled in every API deployment; no existing business route needs them.
ASYNC_EFFECT_V1_ENABLED=false
ASYNC_EFFECT_WORKER_ENABLED=false
EVIDENCE_ROLLOUT_RETENTION_DAYS=30
# Dedicated 32+ byte HMAC key for request/operation/attempt evidence IDs.
# Never reuse an identity, provider, API, or session credential. Without this
# value, shadow metrics use a process-local key and cannot safely correlate
# operation retries across an API restart.
OPERATIONS_EVIDENCE_HMAC_KEY=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions

VOLCENGINE_API_KEY=
VOLCENGINE_VOICE_TYPE=zh_female_cancan_mars_bigtts
VOLCENGINE_APP_ID=
VOLCENGINE_APP_KEY=YOUR_VOLCENGINE_APP_KEY
VOLCENGINE_APP_TOKEN=
VOLCENGINE_REALTIME_RESOURCE_ID=volc.speech.dialog
VOLCENGINE_REALTIME_ADDRESS=wss://openspeech.bytedance.com
VOLCENGINE_REALTIME_URI=/api/v3/realtime/dialogue
VOLCENGINE_VOICE_CLONE_API_KEY=
VOLCENGINE_VOICE_CLONE_TRAIN_URL=https://openspeech.bytedance.com/api/v3/tts/voice_clone
VOLCENGINE_VOICE_CLONE_QUERY_URL=https://openspeech.bytedance.com/api/v3/tts/get_voice
VOLCENGINE_VOICE_CLONE_UPGRADE_URL=https://openspeech.bytedance.com/api/v3/tts/upgrade_voice
VOLCENGINE_VOICE_CLONE_SPEAKER_ID_MODE=customSpeakerId
# VOLCENGINE_VOICE_CLONE_SPEAKER_ID=S_xxxxxxxx
# 声音复刻 2.0 试用槽位可切到 trialSpeakerIdPool，并填控制台赠送的 S_ 音色 ID 列表。
# 后端会把这些槽持久化独占分配给逻辑 voiceProfileId；删除后槽位退休，不会自动复用。
# 试用槽数量就是可绑定 profile 的上限，生产环境应配置足够容量或切换正式资源。
# VOLCENGINE_VOICE_CLONE_SPEAKER_ID_MODE=trialSpeakerIdPool
# VOLCENGINE_VOICE_CLONE_SPEAKER_IDS=S_xxxxxxxx,S_yyyyyyyy
VOLCENGINE_VOICE_CLONE_MODEL_TYPE=5
VOLCENGINE_VOICE_CLONE_TTS_API_KEY=
VOLCENGINE_VOICE_CLONE_TTS_URL=https://openspeech.bytedance.com/api/v1/tts
VOLCENGINE_VOICE_CLONE_TTS_CLUSTER=volcano_icl
VOLCENGINE_VOICE_CLONE_TTS_RESOURCE_ID=seed-icl-2.0

AMAP_WEB_SERVICE_KEY=

# Tencent Cloud Digital Human cloud-rendering session.
# APP_KEY and ACCESS_TOKEN come from the Tencent digital-human session/API console.
# Configure exactly one render asset source: ASSET_VIRTUALMAN_KEY or VIRTUALMAN_PROJECT_ID.
TENCENT_DIGITAL_HUMAN_APP_KEY=
TENCENT_DIGITAL_HUMAN_ACCESS_TOKEN=
TENCENT_DIGITAL_HUMAN_ASSET_VIRTUALMAN_KEY=
TENCENT_DIGITAL_HUMAN_VIRTUALMAN_PROJECT_ID=
# ASR-only fields. Leave empty unless Tencent ASR is enabled.
TENCENT_DIGITAL_HUMAN_APP_ID=
TENCENT_DIGITAL_HUMAN_SECRET_ID=
TENCENT_DIGITAL_HUMAN_SECRET_KEY=
