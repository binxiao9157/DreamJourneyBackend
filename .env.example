APP_ENV=production
PUBLIC_BASE_URL=https://api.example.com
STORE_BACKEND=postgres

DATABASE_URL=postgresql://dreamjourney:dreamjourney@postgres:5432/dreamjourney
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
REDIS_URL=redis://redis:6379/0
BACKEND_API_TOKEN=

# Keep ownership in shadow until mismatch evidence has been reviewed.
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_OWNERSHIP_MODE=shadow
# Observe route/command policy mismatches before enabling server-side denial.
RELEASE_POLICY_COMMAND_MODE=observe

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions

VOLCENGINE_API_KEY=
VOLCENGINE_VOICE_TYPE=zh_female_cancan_mars_bigtts
VOLCENGINE_APP_ID=
VOLCENGINE_APP_KEY=YOUR_VOLCENGINE_APP_KEY
VOLCENGINE_APP_TOKEN=
VOLCENGINE_REALTIME_RESOURCE_ID=volc.speech.dialog
VOLCENGINE_REALTIME_ADDRESS=wss://openspeech.bytedance.com
VOLCENGINE_REALTIME_URI=/api/v3/realtime/dialogue
VOLCENGINE_VOICE_CLONE_API_KEY=
VOLCENGINE_VOICE_CLONE_TRAIN_URL=https://openspeech.bytedance.com/api/v3/tts/voice_clone
VOLCENGINE_VOICE_CLONE_QUERY_URL=https://openspeech.bytedance.com/api/v3/tts/get_voice
VOLCENGINE_VOICE_CLONE_UPGRADE_URL=https://openspeech.bytedance.com/api/v3/tts/upgrade_voice
VOLCENGINE_VOICE_CLONE_SPEAKER_ID_MODE=customSpeakerId
# VOLCENGINE_VOICE_CLONE_SPEAKER_ID=S_xxxxxxxx
# 声音复刻 2.0 试用槽位可切到 trialSpeakerIdPool，并填控制台赠送的 S_ 音色 ID 列表。
# 后端会把这些槽持久化独占分配给逻辑 voiceProfileId；删除后槽位退休，不会自动复用。
# 试用槽数量就是可绑定 profile 的上限，生产环境应配置足够容量或切换正式资源。
# VOLCENGINE_VOICE_CLONE_SPEAKER_ID_MODE=trialSpeakerIdPool
# VOLCENGINE_VOICE_CLONE_SPEAKER_IDS=S_xxxxxxxx,S_yyyyyyyy
VOLCENGINE_VOICE_CLONE_MODEL_TYPE=5
VOLCENGINE_VOICE_CLONE_TTS_API_KEY=
VOLCENGINE_VOICE_CLONE_TTS_URL=https://openspeech.bytedance.com/api/v1/tts
VOLCENGINE_VOICE_CLONE_TTS_CLUSTER=volcano_icl
VOLCENGINE_VOICE_CLONE_TTS_RESOURCE_ID=seed-icl-2.0

AMAP_WEB_SERVICE_KEY=

# Tencent Cloud Digital Human cloud-rendering session.
# APP_KEY and ACCESS_TOKEN come from the Tencent digital-human session/API console.
# Configure exactly one render asset source: ASSET_VIRTUALMAN_KEY or VIRTUALMAN_PROJECT_ID.
TENCENT_DIGITAL_HUMAN_APP_KEY=
TENCENT_DIGITAL_HUMAN_ACCESS_TOKEN=
TENCENT_DIGITAL_HUMAN_ASSET_VIRTUALMAN_KEY=
TENCENT_DIGITAL_HUMAN_VIRTUALMAN_PROJECT_ID=
# ASR-only fields. Leave empty unless Tencent ASR is enabled.
TENCENT_DIGITAL_HUMAN_APP_ID=
TENCENT_DIGITAL_HUMAN_SECRET_ID=
TENCENT_DIGITAL_HUMAN_SECRET_KEY=
